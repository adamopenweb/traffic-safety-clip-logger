# Normalize line endings. This repo is Linux-first; shell scripts, Dockerfiles,
# and systemd units MUST stay LF or they break on Ubuntu (bad interpreter).
* text=auto eol=lf

*.sh        text eol=lf
Makefile    text eol=lf
Dockerfile* text eol=lf
*.service   text eol=lf
*.py        text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf

# Binaries — never normalize.
*.mp4 binary
*.jpg binary
*.png binary
*.pt  binary
*.onnx binary
